import matplotlib.pyplot as plt

def f(x, y):
    return -y + 70

x, y = 0, 100
h = 0.1

xs, ys = [], []

print("RUNGE-KUTTA ORDEN 4")
print("x\t y")

for i in range(20):
    xs.append(x)
    ys.append(y)
    print(f"{x:.1f}\t{y:.2f}")

    k1 = h * f(x, y)
    k2 = h * f(x + h/2, y + k1/2)
    k3 = h * f(x + h/2, y + k2/2)
    k4 = h * f(x + h, y + k3)

    y = y + (k1 + 2*k2 + 2*k3 + k4)/6
    x = x + h

plt.plot(xs, ys)
plt.title("Runge-Kutta Orden 4")
plt.grid()
plt.show()
