import matplotlib.pyplot as plt

def f(x, y):
    return -y + 70

x, y = 0, 100
h = 0.1

xs, ys = [], []

print("RUNGE-KUTTA ORDEN 2")
print("x\t y")

for i in range(20):
    xs.append(x)
    ys.append(y)
    print(f"{x:.1f}\t{y:.2f}")

    k1 = f(x, y)
    k2 = f(x + h/2, y + (h/2)*k1)

    y = y + h*k2
    x = x + h

plt.plot(xs, ys)
plt.title("Runge-Kutta Orden 2")
plt.grid()
plt.show()
