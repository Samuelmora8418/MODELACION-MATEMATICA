import matplotlib.pyplot as plt

def f(x, y):
    return -y + 70

x, y = 0, 100
h = 0.1

xs, ys = [], []

print("EULER")
print("x\t y")

for i in range(20):
    xs.append(x)
    ys.append(y)
    print(f"{x:.1f}\t{y:.2f}")

    y = y + h * f(x, y)
    x = x + h

plt.plot(xs, ys)
plt.title("Metodo de Euler")
plt.grid()
plt.show()
